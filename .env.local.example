# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-xxx

# API-Sports (fallback data source, $10/mo)
API_SPORTS_KEY=your-api-sports-key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Ads (AdWords) conversion tracking — optional
# Get your ID from Google Ads console (format: AW-XXXXXXXXX)
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXX

# Upstash Redis (for digest caching + rate limiting)
# Create free DB at https://upstash.com → copy REST URL and token
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Cron secret (for securing the digest generation endpoint)
# Generate with: openssl rand -base64 32
CRON_SECRET=generate-a-random-string

# Resend (for magic link emails)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@sportingchance.app

# Stripe (subscriptions)
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
# Create webhook at https://dashboard.stripe.com/webhooks → endpoint: /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# Create products/prices in Stripe Dashboard → copy price IDs
STRIPE_MONTHLY_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_YEARLY_PRICE_ID=price_xxxxxxxxxxxx
